menu "ICM-42670-P IMU Configuration"

    config IMU_I2C_SDA_GPIO
        int "I2C SDA GPIO number"
        default 4
        range 0 21
        help
            GPIO pin for I2C SDA line connected to the ICM-42670-P.

    config IMU_I2C_SCL_GPIO
        int "I2C SCL GPIO number"
        default 5
        range 0 21
        help
            GPIO pin for I2C SCL line connected to the ICM-42670-P.

    config IMU_I2C_FREQ_HZ
        int "I2C clock frequency (Hz)"
        default 400000
        range 100000 1000000
        help
            I2C master clock frequency. The ICM-42670-P supports up to 1 MHz.
            400 kHz (Fast Mode) is a safe default.

    config IMU_AD0_HIGH
        bool "AD0 pin is pulled HIGH (I2C address 0x69)"
        default n
        help
            When the ICM-42670-P AP_AD0 pin is tied HIGH the 7-bit
            I2C address becomes 0x69 instead of the default 0x68.

endmenu

menu "Motor Configuration"

    config MOTOR_1_PWM_GPIO
        int "Motor 1 PWM GPIO"
        default 0
        range 0 21
        help
            PWM output pin for motor 1.

    config MOTOR_1_DIR_GPIO
        int "Motor 1 direction GPIO"
        default 1
        range 0 21
        help
            Direction control pin for motor 1.

    config MOTOR_2_PWM_GPIO
        int "Motor 2 PWM GPIO"
        default 3
        range 0 21
        help
            PWM output pin for motor 2.

    config MOTOR_2_DIR_GPIO
        int "Motor 2 direction GPIO"
        default 4
        range 0 21
        help
            Direction control pin for motor 2.

    config MOTOR_3_PWM_GPIO
        int "Motor 3 PWM GPIO"
        default 5
        range 0 21
        help
            PWM output pin for motor 3.

    config MOTOR_3_DIR_GPIO
        int "Motor 3 direction GPIO"
        default 6
        range 0 21
        help
            Direction control pin for motor 3.

    config MOTOR_4_PWM_GPIO
        int "Motor 4 PWM GPIO"
        default 7
        range 0 21
        help
            PWM output pin for motor 4.

    config MOTOR_4_DIR_GPIO
        int "Motor 4 direction GPIO"
        default 9
        range 0 21
        help
            Direction control pin for motor 4.

endmenu
