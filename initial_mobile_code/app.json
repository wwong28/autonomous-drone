{
  "expo": {
    "name": "Aero Drone App",
    "slug": "aero-drone-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.aerodroneapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Aero Drone App needs local network access to connect to your drone's WiFi for video streaming.",
        "NSLocationWhenInUseUsageDescription": "Location permission is required to detect WiFi networks for drone connection."
      }
    },
    "android": {
      "package": "com.anonymous.aerodroneapp",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "enableProguardInReleaseBuilds": true
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "bluetoothAlwaysPermission": "Allow Aero Drone App to connect to your drone via Bluetooth."
        }
      ],
      "react-native-wifi-reborn"
    ],
    "extra": {
      "eas": {
        "projectId": "f5eeacf4-abe3-4c2d-bf8d-eaa0d7c8175e"
      }
    }
  }
}
